      <column caption='AVG([GDP per Capita])' datatype='string' name='[Calculation_620652332972978176]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF AVG([GDP per Capita]) &gt;= 12000&#13;&#10;THEN &quot;Rich Countries&quot;&#13;&#10;ELSE &quot;Poor Countries&quot;&#13;&#10;END' />
      </column>
      <column caption='Economy Status' datatype='string' name='[Calculation_95982973230632960]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF ISNULL({ FIXED [Country] : MEDIAN([GDP per Capita]) }) THEN&#13;&#10;    &quot;Unknown&quot;&#13;&#10;&#13;&#10;ELSEIF { FIXED [Country] : MEDIAN([GDP per Capita]) } &gt;= 12000 THEN&#13;&#10;    &quot;Rich Countries&quot;&#13;&#10;&#13;&#10;ELSE&#13;&#10;    &quot;Poor Countries&quot;&#13;&#10;&#13;&#10;END' />
      </column>
      <column caption='Complete Record' datatype='boolean' name='[Calculation_95982973989863425]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='NOT ISNULL([Adjusted Total Damage])&#13;&#10;AND&#13;&#10;NOT ISNULL([Total Affected])&#13;&#10;AND&#13;&#10;NOT ISNULL([Total Deaths])' />
      </column>
      <column caption='Total Deaths KPI' datatype='string' name='[Calculation_95982974203310082]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF SUM([Total Deaths]) &gt;= 1000000 THEN&#13;&#10;    STR(ROUND(SUM([Total Deaths])/1000000,2)) + &quot;M&quot;&#13;&#10;ELSEIF SUM([Total Deaths]) &gt;= 1000 THEN&#13;&#10;    STR(ROUND(SUM([Total Deaths])/1000,2)) + &quot;K&quot;&#13;&#10;ELSE&#13;&#10;    STR(ROUND(SUM([Total Deaths]),0))&#13;&#10;END' />
      </column>
      <column caption='Economic Damage - KPI ' datatype='string' name='[Calculation_95982974203670531]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF SUM([Adjusted Total Damage]) &gt;= 1000000000 THEN&#13;&#10;&#13;&#10;STR(ROUND(SUM([Adjusted Total Damage])/1000000000,2)) + &quot;B&quot;&#13;&#10;&#13;&#10;ELSEIF SUM([Adjusted Total Damage]) &gt;= 1000000 THEN&#13;&#10;&#13;&#10;STR(ROUND(SUM([Adjusted Total Damage])/1000000,2)) + &quot;M&quot;&#13;&#10;&#13;&#10;ELSEIF SUM([Adjusted Total Damage]) &gt;= 1000 THEN&#13;&#10;&#13;&#10;STR(ROUND(SUM([Adjusted Total Damage])/1000,2)) + &quot;K&quot;&#13;&#10;&#13;&#10;ELSE&#13;&#10;&#13;&#10;STR(ROUND(SUM([Adjusted Total Damage]),0))&#13;&#10;&#13;&#10;END' />
      </column>
      <column caption='Total Affected - KPI ' datatype='string' name='[Calculation_95982974203998212]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF SUM([Total Affected]) &gt;= 1000000000 THEN&#13;&#10;    STR(ROUND(SUM([Total Affected])/1000000000,2)) + &quot;B&quot;&#13;&#10;ELSEIF SUM([Total Affected]) &gt;= 1000000 THEN&#13;&#10;    STR(ROUND(SUM([Total Affected])/1000000,2)) + &quot;M&quot;&#13;&#10;ELSEIF SUM([Total Affected]) &gt;= 1000 THEN&#13;&#10;    STR(ROUND(SUM([Total Affected])/1000,2)) + &quot;K&quot;&#13;&#10;ELSE&#13;&#10;    STR(ROUND(SUM([Total Affected]),0))&#13;&#10;END' />
