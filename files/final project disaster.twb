              <calculation class='tableau' formula='IF SUM([Total Affected]) &gt;= 1000000000 THEN&#13;&#10;    STR(ROUND(SUM([Total Affected])/1000000000,2)) + &quot;B&quot;&#13;&#10;ELSEIF SUM([Total Affected]) &gt;= 1000000 THEN&#13;&#10;    STR(ROUND(SUM([Total Affected])/1000000,2)) + &quot;M&quot;&#13;&#10;ELSEIF SUM([Total Affected]) &gt;= 1000 THEN&#13;&#10;    STR(ROUND(SUM([Total Affected])/1000,2)) + &quot;K&quot;&#13;&#10;ELSE&#13;&#10;    STR(ROUND(SUM([Total Affected]),0))&#13;&#10;END' />
