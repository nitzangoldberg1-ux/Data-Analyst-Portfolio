      <aliases enabled='yes' />
      <column caption='Date Calculat' datatype='integer' name='[Calculation_1439744508217032706]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='DATEDIFF(&apos;day&apos;,[Launch Date],[Deadline Date])' />
      </column>
      <column caption='Top Projects Filter' datatype='boolean' name='[Calculation_1695042314585137153]' role='measure' type='nominal'>
        <calculation class='tableau' formula='INDEX()&lt;= [Parameters].[Parameter 1]'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Avg Per Backer' datatype='real' name='[Calculation_1695042314602954755]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Pledged Amount USD])/SUM([Backers])' />
      </column>
      <column caption='Pledged Containers' datatype='string' name='[Calculation_521291662087417856]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='CASE TRUE &#13;&#10;    WHEN [Pledged Amount USD] &lt;= 500 THEN &quot;0–500&quot;&#13;&#10;    WHEN [Pledged Amount USD] &lt;= 1000 THEN &quot;500–1,000&quot;&#13;&#10;    WHEN [Pledged Amount USD] &lt;= 3000 THEN &quot;1,000–3,000&quot;&#13;&#10;    WHEN [Pledged Amount USD] &lt;= 5000 THEN &quot;3,000–5,000&quot;&#13;&#10;    WHEN [Pledged Amount USD] &lt;= 10000 THEN &quot;5,000–10,000&quot;&#13;&#10;    ELSE &quot;More than 10,000&quot;&#13;&#10;END' />
      </column>
